# Docker Compose 环境变量
# 使用方法: cp .env.example .env，然后修改对应值

# ===== MySQL =====
MYSQL_ROOT_PASSWORD=rootpass
DB_NAME=moment_blog
DB_USER=kanle
DB_PASSWORD=change-me

# ===== 后端 =====
JWT_SECRET=please-generate-a-long-random-string
JWT_EXPIRES_IN=7d
ADMIN_EMAIL=admin@kanle.net
ADMIN_PASSWORD=123456
ADMIN_USERNAME=admin
# 前端地址（CORS + revalidate 回调）
# 本地默认 http://localhost:3000；生产填真实域名如 https://yourdomain.com
CLIENT_URL=http://localhost:3000
REVALIDATE_SECRET=kanle-revalidate

# ===== 前端构建参数（修改后需重新 build 前端）=====
# 注意：结尾必须保留 /api
# 本地: http://localhost:4000/api  生产: https://yourdomain.com/api
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_TWIKOO_ENV_ID=
