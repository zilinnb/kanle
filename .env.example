# Docker Compose 环境变量
# 使用方法: cp .env.example .env，然后修改对应值

# ===== MySQL =====
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_VERSION=8.0                     # 5.7 或 8.0 均可
DB_NAME=moment_blog
DB_USER=kanle
DB_PASSWORD=change-me

# ===== 后端 =====
JWT_SECRET=please-generate-a-long-random-string
JWT_EXPIRES_IN=7d
ADMIN_EMAIL=admin@kanle.net
ADMIN_PASSWORD=123456
ADMIN_USERNAME=admin
# CLIENT_URL 已在 docker-compose.yml 中硬编码为 Docker 内部地址（http://kanle-frontend:3000）
# 用于后端触发前端 ISR 缓存失效，无需修改
REVALIDATE_SECRET=kanle-revalidate

# ===== 前端 =====
# 预构建镜像已内置 NEXT_PUBLIC_API_URL=/api + BACKEND_URL=http://kanle-backend:4000
# /api 是相对路径，通过 Next.js rewrites 代理到后端，任何 IP/域名都能用
# 如需从源码构建（如改后端容器名），取消 docker-compose.yml 中 build 的注释
NEXT_PUBLIC_TWIKOO_ENV_ID=
